# Server Configuration
NODE_ENV=production
PORT=5000

# CORS Configuration
# Set this to your frontend URL in production (e.g., https://your-app.vercel.app)
CORS_ORIGIN=*

# Email Configuration (Resend)
# API Key: https://resend.com/api-keys から取得
RESEND_API_KEY=re_xxxxxxxxxxxx

# From アドレス
# 初期：Resendテストドメイン（Resendアカウント所有者にしか送信不可）
# 本番：認証済み ielove-partners.jp サブドメイン（例: kaketsuke@ielove-partners.jp）
RESEND_FROM_EMAIL=onboarding@resend.dev
